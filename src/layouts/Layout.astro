---
import "../styles/global.css";
---

<!doctype html>
<html lang="fr" class="dark scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Akram Difallah - Portfolio</title>
        <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
        <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
	</head>
	<body class="bg-black text-white antialiased selection:bg-white selection:text-black m-0 overflow-x-hidden min-h-screen">
		<!-- 3D Background Container -->
        <div id="webgl-container" class="fixed inset-0 w-screen h-screen -z-10 pointer-events-none mix-blend-screen"></div>
        <div class="data-aura absolute inset-0 w-full h-full pointer-events-none -z-10 transition-opacity duration-300" id="global-aura" style="background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.08) 0%, transparent 40%);"></div>
        
        <!-- Ambient Grid Lines -->
        <div class="fixed inset-0 pointer-events-none z-0 mix-blend-screen opacity-20">
            <div class="ambient-line absolute bg-white/10 w-px h-full top-0" style="left: 10%;"></div>
            <div class="ambient-line absolute bg-white/10 w-px h-full top-0" style="left: 50%;"></div>
            <div class="ambient-line absolute bg-white/10 w-px h-full top-0" style="left: 90%;"></div>
            <div class="ambient-line absolute bg-white/10 h-px w-full left-0" style="top: 20%;"></div>
            <div class="ambient-line absolute bg-white/10 h-px w-full left-0" style="top: 80%;"></div>
        </div>

        <div id="interactive-wrapper" class="relative z-10 transition-transform duration-100 ease-out" style="transform-style: preserve-3d;">
		    <slot />
        </div>

        <!-- Fixed UI elements: outside tilt wrapper so they render flat -->
        <div id="fixed-ui">
            <slot name="fixed" />
        </div>

        <style is:global>
            /* Glitch Effect */
            .glitch-wrapper {
                position: relative;
                display: inline-block;
            }
            .glitch-text {
                position: relative;
                color: white;
                z-index: 2;
            }
            .glitch-layer {
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                opacity: 0.8;
            }
            .glitch-layer-1 {
                color: rgba(255, 255, 255, 0.7);
                transform: translate(-2px, 1px);
                clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);
                animation: glitch-anim-1 2.5s infinite linear alternate-reverse;
            }
            .glitch-layer-2 {
                color: rgba(255, 255, 255, 0.5);
                transform: translate(2px, -1px);
                clip-path: polygon(0 55%, 100% 55%, 100% 100%, 0 100%);
                animation: glitch-anim-2 3s infinite linear alternate-reverse;
            }
            @keyframes glitch-anim-1 {
                0% { clip-path: inset(20% 0 80% 0); transform: translate(-2px, 1px); }
                20% { clip-path: inset(60% 0 10% 0); transform: translate(2px, -1px); }
                40% { clip-path: inset(40% 0 50% 0); transform: translate(1px, 2px); }
                60% { clip-path: inset(80% 0 5% 0); transform: translate(-1px, -2px); }
                80% { clip-path: inset(10% 0 70% 0); transform: translate(2px, 1px); }
                100% { clip-path: inset(30% 0 50% 0); transform: translate(-2px, -1px); }
            }
            @keyframes glitch-anim-2 {
                0% { clip-path: inset(10% 0 60% 0); transform: translate(2px, -1px); }
                20% { clip-path: inset(30% 0 20% 0); transform: translate(-1px, 2px); }
                40% { clip-path: inset(70% 0 10% 0); transform: translate(2px, 1px); }
                60% { clip-path: inset(20% 0 50% 0); transform: translate(-2px, -1px); }
                80% { clip-path: inset(50% 0 30% 0); transform: translate(1px, 2px); }
                100% { clip-path: inset(5% 0 80% 0); transform: translate(-1px, -2px); }
            }

            /* Data Shards */
            .data-shard {
                background: rgba(10, 10, 10, 0.7);
                backdrop-filter: blur(4px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                position: relative;
                transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
                clip-path: polygon(0 10px, 10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%);
            }
            .data-shard:hover {
                border-color: rgba(255, 255, 255, 0.35);
                background: rgba(18, 18, 18, 0.9);
                box-shadow: 0 0 30px rgba(255, 255, 255, 0.04);
                z-index: 20;
            }

            .micro-data {
                writing-mode: vertical-rl;
                letter-spacing: 2px;
            }

            /* Command Center Nav */
            .cmd-link {
                transition: all 0.2s;
                cursor: pointer;
                position: relative;
                overflow: hidden;
            }
            .cmd-link:hover, .cmd-link.active {
                color: #fff;
                background: rgba(255,255,255,0.1);
                border-color: rgba(255,255,255,0.3);
            }
            .cmd-link::before {
                content: '>';
                margin-right: 8px;
                opacity: 0;
                transition: opacity 0.2s;
            }
            .cmd-link:hover::before, .cmd-link.active::before {
                opacity: 1;
            }
            .cmd-link .blink {
                animation: blinker 1s linear infinite;
            }
            @keyframes blinker {
                50% { opacity: 0; }
            }

            /* Chat window popup animation */
            @keyframes chat-pop-up {
                0%   { opacity: 0; transform: translateY(16px) scale(0.96); }
                100% { opacity: 1; transform: translateY(0)    scale(1);    }
            }
            @keyframes chat-pop-down {
                0%   { opacity: 1; transform: translateY(0)    scale(1);    }
                100% { opacity: 0; transform: translateY(16px) scale(0.96); }
            }
            #chat-window.chat-visible {
                animation: chat-pop-up 0.22s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
            }
            #chat-window.chat-hiding {
                animation: chat-pop-down 0.18s ease-in forwards;
                pointer-events: none;
            }

            /* Chat toggle button — subtle breathing ring so it's always findable */
            #chat-toggle-btn::after {
                content: '';
                position: absolute;
                inset: -4px;
                border: 1px solid rgba(255,255,255,0.2);
                animation: btn-breathe 3s ease-in-out infinite;
            }
            @keyframes btn-breathe {
                0%,100% { opacity: 0.15; transform: scale(1);    }
                50%      { opacity: 0.5;  transform: scale(1.08); }
            }
            #chat-toggle-btn:hover::after {
                animation: none;
                opacity: 0.6;
            }
        </style>

        <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
        
		<script is:inline>
            // Global interactivity variables
            let mouseX = window.innerWidth / 2;
            let mouseY = window.innerHeight / 2;
            let targetX = 0;
            let targetY = 0;
            let windowHalfX = window.innerWidth / 2;
            let windowHalfY = window.innerHeight / 2;

            // Track mouse movement for tilt and aura
            document.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
                
                // Tilt calculation — very subtle
                targetX = (mouseX - windowHalfX) * 0.004;
                targetY = (mouseY - windowHalfY) * 0.004;

                // Aura effect update
                const aura = document.getElementById('global-aura');
                if (aura) {
                    aura.style.setProperty('--mouse-x', `${(mouseX / window.innerWidth) * 100}%`);
                    aura.style.setProperty('--mouse-y', `${(mouseY / window.innerHeight) * 100}%`);
                }
            });

            // Apply tilt to main wrapper — perspective lives ON the element, not on body
            // (perspective on body would break position:fixed for all children)
            function updateTilt() {
                const wrapper = document.getElementById('interactive-wrapper');
                if (wrapper) {
                    wrapper.style.transform = `perspective(1200px) rotateY(${targetX}deg) rotateX(${-targetY}deg)`;
                }
                requestAnimationFrame(updateTilt);
            }
            updateTilt();

            // Neural Synapse Simulation (Three.js WebGL replacement)
            const container = document.getElementById('webgl-container');
            if (container) {
                const scene = new THREE.Scene();
                // Vantablack fog
                scene.fog = new THREE.FogExp2(0x000000, 0.002);

                const camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 1000);
                const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
                
                renderer.setSize(window.innerWidth, window.innerHeight);
                renderer.setPixelRatio(window.devicePixelRatio);
                container.appendChild(renderer.domElement);

                // Neural Synapse Nodes
                const nodeCount = 300;
                const geometry = new THREE.BufferGeometry();
                const positions = new Float32Array(nodeCount * 3);
                const velocities = [];

                // Monochrome material
                const pbrMaterial = new THREE.MeshBasicMaterial({
                    color: 0xffffff,
                    transparent: true,
                    opacity: 0.8
                });

                const lineMaterial = new THREE.LineBasicMaterial({
                    color: 0xffffff,
                    transparent: true,
                    opacity: 0.05
                });

                const nodeGeometry = new THREE.OctahedronGeometry(1, 0); // Geometric shape

                for (let i = 0; i < nodeCount; i++) {
                    const x = (Math.random() - 0.5) * 600;
                    const y = (Math.random() - 0.5) * 600;
                    const z = (Math.random() - 0.5) * 400 - 100;

                    positions[i * 3] = x;
                    positions[i * 3 + 1] = y;
                    positions[i * 3 + 2] = z;

                    velocities.push({
                        x: (Math.random() - 0.5) * 0.2,
                        y: (Math.random() - 0.5) * 0.2,
                        z: (Math.random() - 0.5) * 0.2
                    });

                    const sizeScale = Math.random() > 0.8 ? 2 : 0.5;
                    const mesh = new THREE.Mesh(nodeGeometry, pbrMaterial);
                    mesh.position.set(x, y, z);
                    mesh.scale.setScalar(sizeScale);
                    mesh.rotation.set(Math.random() * Math.PI, Math.random() * Math.PI, 0);
                    
                    scene.add(mesh);
                }

                geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));

                // Initial lines setup
                const lineGeo = new THREE.BufferGeometry();
                const linePos = new Float32Array(nodeCount * nodeCount * 3); // Over-allocate, update dynamically
                lineGeo.setAttribute('position', new THREE.BufferAttribute(linePos, 3));
                const lines = new THREE.LineSegments(lineGeo, lineMaterial);
                scene.add(lines);

                camera.position.z = 150;

                // Animation Loop
                let time = 0;
                function animate() {
                    requestAnimationFrame(animate);
                    time += 0.01;

                    // Camera subtle pan based on mouse
                    camera.position.x += (targetX * 5 - camera.position.x) * 0.05;
                    camera.position.y += (-targetY * 5 - camera.position.y) * 0.05;
                    camera.lookAt(scene.position);

                    // Update synapse nodes positions
                    const meshes = scene.children.filter(c => c.type === 'Mesh');
                    const posArray = geometry.attributes.position.array;
                    
                    let lineIdx = 0;

                    for(let i=0; i<nodeCount; i++) {
                        // Drift
                        meshes[i].position.x += velocities[i].x;
                        meshes[i].position.y += velocities[i].y;
                        meshes[i].position.z += velocities[i].z;
                        meshes[i].rotation.x += 0.01;
                        meshes[i].rotation.y += 0.01;

                        // Bounds check
                        if(Math.abs(meshes[i].position.x) > 300) velocities[i].x *= -1;
                        if(Math.abs(meshes[i].position.y) > 300) velocities[i].y *= -1;
                        if(meshes[i].position.z > 100 || meshes[i].position.z < -400) velocities[i].z *= -1;

                        posArray[i*3] = meshes[i].position.x;
                        posArray[i*3+1] = meshes[i].position.y;
                        posArray[i*3+2] = meshes[i].position.z;

                        // Calculate connections dynamically
                        for(let j=i+1; j<nodeCount; j++) {
                            const dx = meshes[i].position.x - meshes[j].position.x;
                            const dy = meshes[i].position.y - meshes[j].position.y;
                            const dz = meshes[i].position.z - meshes[j].position.z;
                            const distSq = dx*dx + dy*dy + dz*dz;
                            
                            // Connection threshold
                            if(distSq < 4000) {
                                linePos[lineIdx++] = meshes[i].position.x;
                                linePos[lineIdx++] = meshes[i].position.y;
                                linePos[lineIdx++] = meshes[i].position.z;
                                linePos[lineIdx++] = meshes[j].position.x;
                                linePos[lineIdx++] = meshes[j].position.y;
                                linePos[lineIdx++] = meshes[j].position.z;
                            }
                        }
                    }
                    
                    // Update lines
                    lines.geometry.setDrawRange(0, lineIdx / 3);
                    lines.geometry.attributes.position.needsUpdate = true;

                    renderer.render(scene, camera);
                }

                animate();

                // Resize Handler
                window.addEventListener('resize', () => {
                    windowHalfX = window.innerWidth / 2;
                    windowHalfY = window.innerHeight / 2;
                    camera.aspect = window.innerWidth / window.innerHeight;
                    camera.updateProjectionMatrix();
                    renderer.setSize(window.innerWidth, window.innerHeight);
                });
            }

            // Command center active state logic
            document.addEventListener("DOMContentLoaded", () => {
                const cmdLinks = document.querySelectorAll('.cmd-link');
                cmdLinks.forEach(link => {
                    link.addEventListener('click', function(e) {
                        cmdLinks.forEach(l => l.classList.remove('active'));
                        this.classList.add('active');
                    });
                });
            });
		</script>
	</body>
</html>
